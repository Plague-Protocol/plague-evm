// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomStatus {
  waiting
  starting
  active
  ended
}

model Room {
  id          String     @id @default(cuid())
  roomId      String     @unique
  hostAddress String
  status      RoomStatus @default(waiting)
  name        String?

  maxPlayers  Int
  stakeAmount String
  proofFee    String

  createdAt   DateTime   @default(now())
  expiresAt   DateTime

  chainId         Int
  contractAddress String

  players     RoomPlayer[]

  @@index([status, expiresAt])
}

model RoomPlayer {
  id        String   @id @default(cuid())
  room      Room     @relation(fields: [roomDbId], references: [id], onDelete: Cascade)
  roomDbId  String
  address   String
  joinedAt  DateTime @default(now())

  @@unique([roomDbId, address])
  @@index([address])
}

model PlayerNickname {
  address  String @id
  nickname String

  updatedAt DateTime @updatedAt

  @@unique([nickname])
}

model GameSummary {
  id              String             @id @default(cuid())
  roomId          String             @unique
  chainId         Int
  contractAddress String
  outcome         String
  totalRounds     Int
  totalPot        String
  potPerWinner    String
  winnerCount     Int
  endedAt         DateTime

  players GameSummaryPlayer[]

  @@index([endedAt])
  @@index([outcome])
}

model GameSummaryPlayer {
  id                  String      @id @default(cuid())
  gameSummary         GameSummary  @relation(fields: [gameSummaryId], references: [id], onDelete: Cascade)
  gameSummaryId       String
  address             String
  displayNameSnapshot String?
  result              String
  proofsSubmittedTotal Int         @default(0)
  statusAtEnd         String
  joinedAt            DateTime?

  @@unique([gameSummaryId, address])
  @@index([address])
  @@index([result])
}
