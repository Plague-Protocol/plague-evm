# Copy to .env.local and fill in your values

# Thirdweb client ID — powers social/email/phone sign-in + wallet connect.
# Create a free project at https://thirdweb.com/dashboard and paste the Client ID.
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id

# Deployed PlagueGame contract address on Celo
NEXT_PUBLIC_CONTRACT_ADDRESS=0xeD416AaAa23B96aCC1263D4E462b3E468059BAA9

# "testnet" (Celo Sepolia 11142220) or "mainnet" (Celo 42220)
NEXT_PUBLIC_NETWORK=testnet

# RPC for on-chain reads (optional). Leave blank to use the chain default.
# Reads use a fallback transport: primary → these fallbacks → built-in defaults,
# so a momentary public-RPC outage doesn't break the lobby. Comma-separated.
NEXT_PUBLIC_CELO_RPC_URL=
NEXT_PUBLIC_CELO_RPC_FALLBACK_URLS=https://celo-sepolia.drpc.org

# Backend socket/API server URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_ROLE_COMMIT_TIMEOUT_MS=180000
NEXT_PUBLIC_ELIMINATION_PHASE_DURATION_MS=6000

# Minimum per-extra-Shield fee (wei). The fee is max(1% of stake, this floor) so
# small-stake rooms don't show a "0" fee. Default 0.001 USDm = 1e15 wei.
NEXT_PUBLIC_MIN_PROOF_FEE_WEI=1000000000000000

# Deployed FaucetCUSD contract address (Celo Sepolia testnet only — leave blank for mainnet)
NEXT_PUBLIC_FAUCET_ADDRESS=
