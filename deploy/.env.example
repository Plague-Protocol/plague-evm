# Copy to deploy/.env and fill in. This file is read by docker compose for
# ${VAR} substitution. deploy/.env is gitignored — never commit real secrets.

# ── Public API domain (Caddy auto-TLS) ──────────────────────────────────────
# DNS A record for this must point at the VPS public IP.
API_DOMAIN=api.zplague.xyz

# Origin allowed by backend CORS (your frontend). zplague.xyz + www are also
# hardcoded in the backend; set this to your primary frontend origin.
FRONTEND_URL=https://zplague.xyz

# ── Celo RPC (keyed upstream strongly recommended) ──────────────────────────
# The backend's /api/rpc proxy serves the whole floor's browser chain-polling
# from THIS one IP, and public Celo nodes (forno, drpc) rate-limit by IP — under
# load they 5xx and the proxy 502s. Point CELO_RPC_URL at a keyed endpoint so
# the proxy (and the backend signer) lean on that; public nodes stay as
# fallbacks. Both default to public if unset, so this whole section is optional.
#   Alchemy: https://celo-mainnet.g.alchemy.com/v2/<KEY>
#   dRPC:    https://lb.drpc.org/ogrpc?network=celo&dkey=<KEY>
#   Infura:  https://celo-mainnet.infura.io/v3/<KEY>
# CELO_RPC_URL=https://celo-mainnet.g.alchemy.com/v2/YOUR_KEY
# CELO_RPC_FALLBACK_URLS=https://forno.celo.org,https://celo.drpc.org
# Both the backend AND the agents fan out over this same primary + fallbacks.

# ── Backend chain event-poll cadence (optional) ─────────────────────────────
# The backend polls contract events via eth_getLogs, fast while a game is live
# and slow when idle. Defaults (compose): 10s active / 60s idle — the 60s idle
# keeps idle RPC burn ~2.6M CU/mo. Lower idle for faster bot self-play pickup,
# raise it to save more. Human games are unaffected (instant via socket join).
# CHAIN_EVENT_POLL_MS=10000
# CHAIN_EVENT_IDLE_POLL_MS=60000

# ── Self-hosted Postgres ────────────────────────────────────────────────────
# Strong random string. Used by both the postgres container and DATABASE_URL.
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# ── Backend secrets ─────────────────────────────────────────────────────────
# Mainnet signer (beginActivePhase/assignInfection/openVoting/resolveRound).
# Fund with a little CELO for gas.
BACKEND_PRIVATE_KEY=0x...
# Shared secret authenticating the agent runner to the backend bot API.
# The agents service reuses this same value below.
BOT_RUNNER_SECRET=change-me-to-a-long-random-string

# ── Agent tuning (optional — sensible defaults in compose) ───────────────────
STAKE_AMOUNT=100000000000000
BOT_MAX_STAKE_WEI=10000000000000000
SELF_PLAY_IDLE_MS=300000
CYCLE_DELAY_MS=30000
# Set true to stop bots starting self-play games (they still join human rooms).
SELF_PLAY_DISABLED=false
# Gas floor (wei of native CELO): bots below this are excluded from games.
# A full game spends ~0.55 CELO, but the node's pre-flight balance check needs
# gasLimit×maxFeePerGas ≈ 0.92 CELO for the ZK commit (baseFeeMultiplier 2);
# a bot that can join but not commit deadlocks the room. Default 1.5 CELO.
MIN_GAME_CELO_WEI=1500000000000000000

# ── Bot wallet keys (fund at least 3, contiguous from _1) ────────────────────
# On mainnet with FEE_CURRENCY_ADDRESS set, fund each with USDm only (no CELO).
BOT_PRIVATE_KEY_1=0x...
BOT_PRIVATE_KEY_2=0x...
BOT_PRIVATE_KEY_3=0x...
BOT_PRIVATE_KEY_4=
BOT_PRIVATE_KEY_5=
