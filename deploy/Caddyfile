# Auto-HTTPS reverse proxy for the Plague backend API.
# Caddy fetches + renews a Let's Encrypt cert for $API_DOMAIN automatically,
# and transparently proxies WebSocket (socket.io) upgrades.
#
# Requires: a DNS A record for $API_DOMAIN → this VPS's public IP, and
# ports 80 + 443 open in the Lighthouse firewall.

{$API_DOMAIN} {
	reverse_proxy backend:4000
}
