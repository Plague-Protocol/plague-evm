# Foundry build artefacts
contracts/out/
cache/
contracts/cache/
contracts/deployment.log
# contracts/lib/ is tracked — forge-std is a git submodule
contracts/lib/*/target/

# ZK keys (never commit trusted setup keys)
zk/keys/*.zkey
zk/keys/*.ptau
zk/proofs/*.json

# Nargo build output (compiled circuit artifacts — run zk/scripts/build-circuits.sh to regenerate)
zk/packages/*/target/
# bb verification key binary artifacts (used to generate *Verifier.sol — not needed in repo)
zk/target/*_vk/

# Circuit JSON artifacts served from frontend — generated by build-circuits.sh
# frontend/public/circuits/*.json

# TypeScript incremental build info
**/*.tsbuildinfo

